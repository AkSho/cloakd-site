---
import Base from '../layouts/Base.astro';

// Swap to test link during testing: https://buy.stripe.com/test_cNifZgdjd6kg65FgYz9AA00
const STRIPE_LINK = 'https://buy.stripe.com/cNifZgdjd6kg65FgYz9AA00';
---

<Base
  title="Rodent Fertility Control NYC & NJ | Monthly Managed Program | Cloakd"
  description="Managed rodent fertility control for NYC and NJ restaurants, property managers, and commercial operators. $349/month. Licensed operator deployment. 79% reduction in monitored rodent activity."
  path="/rodent-fertility-control"
>

  <!-- ─────────────────────────── HERO — two column ── -->
  <section class="pt-12 pb-16 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-[1fr_420px] gap-12 items-start">

        <!-- Left: Hook -->
        <div class="pt-4">
          <p class="text-[#c96a3a] text-sm font-semibold tracking-widest uppercase mb-5">
            Rodent Fertility Control — NYC &amp; NJ
          </p>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-[#1c1814] mb-6">
            Your exterminator is doing their job.<br />
            That's not why it keeps coming back.
          </h1>
          <p class="text-lg text-[#1c1814]/75 leading-relaxed mb-4 max-w-xl">
            Rodent fertility control suppresses the birth rate — the front
            standard treatment never touches. Your exterminator removes what's
            there. Our licensed operator deploys fertility control monthly so
            the replacement colony can't form at full size.
          </p>
          <p class="text-lg text-[#1c1814]/75 leading-relaxed mb-10 max-w-xl">
            Both fronts running at once is why it actually stops.
          </p>

          <!-- Proof strip -->
          <div class="flex flex-wrap gap-10 pt-8 border-t border-[#1c1814]/8">
            {[
              { value: '79%',       label: 'reduction in monitored activity\n5-month urban field study' },
              { value: '88%',       label: 'drop in track count density\nat monitored stations' },
              { value: 'EPA 25(b)', label: 'minimum risk clearance\nsafe in food environments' },
            ].map(({ value, label }) => (
              <div class="flex flex-col gap-1.5">
                <span class="text-3xl font-black text-[#7aab7e]">{value}</span>
                <span class="text-sm text-[#1c1814]/55 leading-snug whitespace-pre-line">{label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Sticky subscription card -->
        <div class="lg:sticky lg:top-24">
          <div class="bg-white border border-[#1c1814]/12 rounded-lg overflow-hidden shadow-sm">

            <!-- Card header -->
            <div class="px-7 pt-7 pb-5 border-b border-[#1c1814]/6">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#c96a3a] mb-2">Monthly subscription</p>
              <div class="flex items-baseline gap-1.5 mb-1">
                <span class="text-4xl font-black text-[#1c1814]">$349</span>
                <span class="text-base text-[#1c1814]/50">/month</span>
              </div>
              <p class="text-sm text-[#1c1814]/50 leading-relaxed">3-month minimum. Month-to-month after. Cancel with 30 days notice.</p>
            </div>

            <!-- Includes -->
            <div class="px-7 py-5 border-b border-[#1c1814]/6">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#1c1814]/40 mb-4">What's included</p>
              <ul class="space-y-3">
                {[
                  'Monthly licensed operator site visit',
                  'Evolve bait station deployment & maintenance',
                  'Track count monitoring — documented monthly',
                  'EPA 25(b) product — safe in food environments',
                  'No changes to your existing pest control vendor',
                ].map((item) => (
                  <li class="flex items-start gap-3">
                    <svg class="flex-shrink-0 mt-0.5" width="14" height="12" viewBox="0 0 14 12" fill="none">
                      <path d="M1.5 6L5.5 10L12.5 1.5" stroke="#5e9263" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="text-sm text-[#1c1814]/75 leading-snug">{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Form -->
            <div class="px-7 py-6">
              <div id="form-step">
                <p class="text-sm font-semibold text-[#1c1814] mb-4">Tell us about your property</p>
                <form id="property-form" class="space-y-3">
                  <input
                    type="text" name="name" required placeholder="Your name"
                    class="w-full px-4 py-3 border border-[#1c1814]/12 rounded text-sm text-[#1c1814] bg-[#faf8f4] placeholder:text-[#1c1814]/35 focus:outline-none focus:border-[#c96a3a]/60 transition-colors"
                  />
                  <select
                    name="property_type" required
                    class="w-full px-4 py-3 border border-[#1c1814]/12 rounded text-sm text-[#1c1814] bg-[#faf8f4] focus:outline-none focus:border-[#c96a3a]/60 transition-colors"
                  >
                    <option value="" disabled selected>Property type</option>
                    <option value="restaurant">Restaurant</option>
                    <option value="ghost_kitchen">Ghost Kitchen</option>
                    <option value="residential_building">Residential Building</option>
                    <option value="commercial_building">Commercial Building</option>
                    <option value="food_storage">Food Storage / Warehouse</option>
                    <option value="hoa">HOA / Co-op</option>
                    <option value="other">Other</option>
                  </select>
                  <input
                    type="text" name="address" required placeholder="Property address"
                    class="w-full px-4 py-3 border border-[#1c1814]/12 rounded text-sm text-[#1c1814] bg-[#faf8f4] placeholder:text-[#1c1814]/35 focus:outline-none focus:border-[#c96a3a]/60 transition-colors"
                  />
                  <input
                    type="email" name="email" id="form-email" required placeholder="Email"
                    class="w-full px-4 py-3 border border-[#1c1814]/12 rounded text-sm text-[#1c1814] bg-[#faf8f4] placeholder:text-[#1c1814]/35 focus:outline-none focus:border-[#c96a3a]/60 transition-colors"
                  />
                  <input
                    type="tel" name="phone" required placeholder="Phone"
                    class="w-full px-4 py-3 border border-[#1c1814]/12 rounded text-sm text-[#1c1814] bg-[#faf8f4] placeholder:text-[#1c1814]/35 focus:outline-none focus:border-[#c96a3a]/60 transition-colors"
                  />
                  <button
                    type="submit"
                    class="w-full py-4 px-6 bg-[#b85530] text-[#faf8f4] font-semibold text-base rounded hover:bg-[#c96a3a] transition-colors mt-1"
                  >
                    Start the program — $349/mo
                  </button>
                </form>
                <p class="mt-3 text-xs text-[#1c1814]/35 text-center">Secure checkout via Stripe. Cancel anytime after month 3.</p>
              </div>

              <div id="confirm-step" class="hidden text-center py-4">
                <div class="w-10 h-10 rounded-full bg-[#7aab7e]/15 flex items-center justify-center mx-auto mb-4">
                  <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
                    <path d="M1.5 7L6.5 12L16.5 1.5" stroke="#5e9263" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <p class="text-base font-semibold text-[#1c1814] mb-2">Redirecting to checkout...</p>
                <p class="text-sm text-[#1c1814]/50">You'll complete your subscription on the next page.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── MECHANISM — IF/THEN truth chain ── -->
  <section class="py-24 px-6 bg-[#f0ebe0]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[#c96a3a] text-sm font-semibold tracking-widest uppercase mb-4">
        Why it keeps coming back
      </p>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-[#1c1814] mb-6 max-w-2xl">
        Treatment works. Biology undoes it.
      </h2>
      <p class="text-lg text-[#1c1814]/65 max-w-xl mb-16 leading-relaxed">
        Follow this through once.
      </p>

      <div class="max-w-3xl">
        {[
          {
            if_: 'Standard extermination removes the active colony',
            then: 'The territory sits vacant. Food source still there. Building still there. Every rat in the surrounding block can detect it.',
          },
          {
            if_: 'The territory sits vacant in a food-dense block',
            then: 'Surrounding rats move in within 4 to 8 weeks. They don\'t come from far away — from the same block, at full breeding capacity.',
          },
          {
            if_: 'The incoming population breeds at full rate',
            then: 'One pair becomes a colony before your next scheduled treatment. You return to the same baseline you started from.',
          },
          {
            if_: 'Nothing changes the reproduction rate',
            then: 'The cycle repeats exactly. Same cost, same timeline, same result. Not a vendor failure — a biology problem single-front treatment can\'t solve.',
          },
        ].map(({ if_, then }) => (
          <div class="grid sm:grid-cols-[1fr_1fr] gap-0 mb-0 border-b border-[#1c1814]/8 last:border-0 py-8">
            <div class="sm:pr-8 sm:border-r border-[#1c1814]/8 mb-4 sm:mb-0">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#1c1814]/35 mb-2">If</p>
              <p class="text-base font-semibold text-[#1c1814] leading-snug">{if_}</p>
            </div>
            <div class="sm:pl-8">
              <p class="text-xs font-semibold uppercase tracking-widest text-[#c96a3a]/70 mb-2">Then</p>
              <p class="text-base text-[#1c1814]/70 leading-relaxed">{then}</p>
            </div>
          </div>
        ))}

        <!-- Resolution -->
        <div class="mt-10 bg-white border border-[#7aab7e]/25 rounded-lg p-8">
          <p class="text-xs font-semibold uppercase tracking-widest text-[#7aab7e] mb-4">What changes with rodent fertility control</p>
          <p class="text-base font-semibold text-[#1c1814] mb-4">
            Suppress the birth rate while removal continues
          </p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <p class="text-sm font-semibold text-[#1c1814] mb-2">In males</p>
              <p class="text-sm text-[#1c1814]/65 leading-relaxed">Regular consumption of Evolve bait reduces working sperm production. Their contribution to the next generation drops over several weeks.</p>
            </div>
            <div>
              <p class="text-sm font-semibold text-[#1c1814] mb-2">In females</p>
              <p class="text-sm text-[#1c1814]/65 leading-relaxed">Fewer litters. Smaller litters. Lower pup survival rate. Across the colony, deaths start exceeding births.</p>
            </div>
          </div>
          <p class="text-base text-[#1c1814]/70 leading-relaxed mt-6 pt-6 border-t border-[#1c1814]/6">
            The colony shrinks from inside while your exterminator hits it from outside. That's when the number actually goes down — and stays down.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── FIELD DATA ── -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-[#c96a3a] text-sm font-semibold tracking-widest uppercase mb-4">
        Field data
      </p>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-[#1c1814] mb-16 max-w-2xl">
        What happens when both fronts run.
      </h2>

      <div class="grid md:grid-cols-3 gap-6 mb-16">
        {[
          {
            stat: '79%',
            label: 'reduction in monitored rodent activity',
            context: '5-month study across two urban NYC locations',
          },
          {
            stat: '88%',
            label: 'drop in track count density',
            context: 'At monitored stations over the same deployment period',
          },
          {
            stat: '90%',
            label: 'fertility reduction',
            context: 'When integrated into an active pest management program',
          },
        ].map(({ stat, label, context }) => (
          <div class="border border-[#1c1814]/10 rounded-lg p-8">
            <p class="text-5xl font-black text-[#7aab7e] mb-3">{stat}</p>
            <p class="text-base font-semibold text-[#1c1814] mb-2">{label}</p>
            <p class="text-sm text-[#1c1814]/50 leading-relaxed">{context}</p>
          </div>
        ))}
      </div>

      <div class="border-t border-[#1c1814]/8 pt-10">
        <p class="text-xs font-semibold uppercase tracking-widest text-[#1c1814]/40 mb-6">Cities running rodent fertility control programs</p>
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            { city: 'New York City', note: 'Designated rat mitigation zones. Active deployment since April 2025.' },
            { city: 'Baltimore', note: 'City-wide rodent control program. Adopted Evolve in 2025.' },
            { city: 'Chicago', note: 'Wicker Park corridor. Positive early results reported March 2026.' },
          ].map(({ city, note }) => (
            <div>
              <div class="flex items-center gap-2 mb-2">
                <div class="w-2 h-2 rounded-full bg-[#7aab7e] flex-shrink-0"></div>
                <span class="text-base font-semibold text-[#1c1814]">{city}</span>
              </div>
              <p class="text-sm text-[#1c1814]/50 leading-relaxed pl-4">{note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── WHO IT'S FOR ── -->
  <section class="py-24 px-6 bg-[#f0ebe0]">
    <div class="max-w-6xl mx-auto">
      <p class="text-[#c96a3a] text-sm font-semibold tracking-widest uppercase mb-4">
        Who this is for
      </p>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-[#1c1814] mb-12 max-w-2xl">
        If the cycle hasn't stopped, this is the missing piece.
      </h2>

      <div class="grid md:grid-cols-2 gap-6">
        {[
          {
            tag: 'NYC & NJ Restaurants',
            body: 'DOHMH violation codes 04K and 04L are critical violations. A single sighting triggers a re-inspection cycle. The fertility control layer — running between your scheduled PCO visits — reduces the active population before the inspector returns. Track count documentation goes with you into any compliance conversation.',
          },
          {
            tag: 'Property Managers',
            body: 'One program across every building you manage. Tenant complaints don\'t stop until the population does. Your exterminator is clearing what\'s there every visit. We stop what fills back in between visits.',
          },
          {
            tag: 'Ghost Kitchens & Food Storage',
            body: 'High-density food environments with constant product cycling and shared harborage. EPA 25(b) minimum risk clearance means Evolve runs continuously in or adjacent to food-handling spaces — no special permits required.',
          },
          {
            tag: 'HOAs & Residential Buildings',
            body: 'Multi-unit buildings share harborage. What one unit treats shows up in another. Fertility control addresses the colony across the building, not unit by unit.',
          },
        ].map(({ tag, body }) => (
          <div class="bg-white border border-[#1c1814]/8 rounded-lg p-8">
            <p class="text-xs font-semibold uppercase tracking-widest text-[#c96a3a] mb-4">{tag}</p>
            <p class="text-base text-[#1c1814]/70 leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── FAQ ── -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-[#c96a3a] text-sm font-semibold tracking-widest uppercase mb-4">
        Common questions
      </p>
      <h2 class="text-4xl font-extrabold text-[#1c1814] mb-12">
        Before you start
      </h2>

      <div id="faq" class="divide-y divide-[#1c1814]/8">
        {[
          {
            q: 'Does this replace my current exterminator?',
            a: 'No. Your existing vendor keeps their contract and their schedule. Cloakd handles fertility control specifically — a separate layer running alongside. Nothing changes on their end.',
          },
          {
            q: 'Do I need to do anything differently?',
            a: 'Provide access for monthly station visits. That\'s it. Our licensed operator handles deployment, bait replenishment, and station maintenance. You don\'t coordinate between the two services.',
          },
          {
            q: 'Is it safe in a restaurant or food service environment?',
            a: 'Yes. Evolve is classified as EPA minimum risk under 25(b) — the same regulatory category as products made from cloves or citronella. No synthetic chemicals. No secondary kill risk to pets or predators. No special permit required for food-handling spaces.',
          },
          {
            q: 'How long until the population goes down?',
            a: 'Fertility suppression builds over 8 to 12 weeks. Track counts typically show measurable decline by month 2. Rate depends on colony size and how much of the population is consistently consuming the bait.',
          },
          {
            q: 'What\'s the minimum commitment?',
            a: 'Three months. That covers one full breeding cycle — enough time to produce a documented trend. After month 3, the subscription is month-to-month with 30 days notice to cancel.',
          },
          {
            q: 'Does Cloakd service NJ as well as NYC?',
            a: 'Yes. Serving NYC\'s five boroughs and the NJ commercial corridor — Bergen, Hudson, Essex counties and surrounding markets. Coverage confirmed at intake.',
          },
          {
            q: 'What if I have mice, not rats?',
            a: 'Evolve is formulated for Norway rats. SenesTech produces a separate product for mice. If your property has mice specifically, mention it at intake and we\'ll confirm the right protocol.',
          },
          {
            q: 'What does the licensed operator actually do each month?',
            a: 'Site visit of 30 to 45 minutes. Check station condition, replenish bait, read tracking plates, note activity. You get a documented record of what the population is doing month over month.',
          },
        ].map(({ q, a }) => (
          <div class="faq-item">
            <button class="faq-trigger w-full flex items-start justify-between gap-6 py-5 text-left" aria-expanded="false">
              <span class="text-base font-semibold text-[#1c1814]">{q}</span>
              <svg class="faq-icon flex-shrink-0 mt-1 w-4 h-4 text-[#1c1814]/35 transition-transform duration-200" viewBox="0 0 16 16" fill="none">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="faq-answer hidden pb-5">
              <p class="text-base text-[#1c1814]/65 leading-relaxed">{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────────── FINAL CTA ── -->
  <section class="py-24 px-6 bg-[#1c1814]">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-[1fr_auto] gap-12 items-center">
        <div>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-[#faf8f4] mb-4">
            The cycle ends when you hit it from both ends.
          </h2>
          <p class="text-lg text-[#faf8f4]/55 leading-relaxed max-w-xl">
            Monthly managed rodent fertility control for NYC and NJ restaurants and commercial properties. $349/month. Licensed operator. Results documented every cycle.
          </p>
        </div>
        <div class="flex flex-col gap-4 flex-shrink-0">
          <a
            href="#form-step"
            onclick="document.getElementById('form-step').closest('section')?.scrollIntoView({behavior:'smooth'}); return false;"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold rounded bg-[#b85530] text-[#faf8f4] hover:bg-[#c96a3a] transition-colors whitespace-nowrap"
          >
            Start the program
          </a>
          <a
            href="/results"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-medium rounded border border-[#faf8f4]/15 text-[#faf8f4]/60 hover:text-[#faf8f4] hover:border-[#faf8f4]/25 transition-colors whitespace-nowrap"
          >
            See the field data
          </a>
        </div>
      </div>
    </div>
  </section>

</Base>

<script define:vars={{ STRIPE_LINK }}>
  const form = document.getElementById('property-form');
  const formStep = document.getElementById('form-step');
  const confirmStep = document.getElementById('confirm-step');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const data = new FormData(form);
    const email = document.getElementById('form-email')?.value ?? '';

    sessionStorage.setItem('cloakd_lead', JSON.stringify({
      name:          data.get('name'),
      property_type: data.get('property_type'),
      address:       data.get('address'),
      email:         data.get('email'),
      phone:         data.get('phone'),
      ts:            new Date().toISOString(),
    }));

    formStep.classList.add('hidden');
    confirmStep.classList.remove('hidden');

    const dest = email
      ? `${STRIPE_LINK}?prefilled_email=${encodeURIComponent(email)}`
      : STRIPE_LINK;

    setTimeout(() => { window.location.href = dest; }, 800);
  });

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer');
      const icon   = trigger.querySelector('.faq-icon');
      const isOpen = !answer?.classList.contains('hidden');

      // Close all others
      document.querySelectorAll('.faq-answer').forEach((a) => a.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach((ic) => ic.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-trigger').forEach((t) => t.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer?.classList.remove('hidden');
        icon?.classList.add('rotate-180');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
